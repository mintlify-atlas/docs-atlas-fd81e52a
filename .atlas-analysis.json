  "keyFeatures": [
    "Agent management — create, load, and manage AI agents via async/sync APIs",
    "Task lifecycle management — create, monitor, stream, and stop task executions",
    "Tools repository — register local tools with @register_tool decorator and invoke remote tools",
    "Knowledge bases — create, search, and manage document repositories with semantic search",
    "Event-driven programming — @on_task, @on_boot, @on_shutdown, and tool hook decorators",
    "MCP server integration — Model Context Protocol server support (STDIO, HTTP)",
    "Multi-framework backend support — Agno, Strands Agents, OpenAI Agents",
    "Real-time event streaming — SSE-based streaming for task execution monitoring",
    "Self-hosted deployment support — configurable base URL for on-premise installations",
    "Async-first with sync wrappers — all public APIs available in both async and sync flavors"
  ],
